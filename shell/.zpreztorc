#
# Prezto configuration
#

# Color output
zstyle ':prezto:*:*' color 'yes'

# Modules to load (order matters)
zstyle ':prezto:load' pmodule \
  'environment' \
  'terminal' \
  'editor' \
  'history' \
  'directory' \
  'spectrum' \
  'utility' \
  'completion' \
  'syntax-highlighting' \
  'autosuggestions' \
  'git' \
  'prompt'

# Set the prompt theme to Pure
zstyle ':prezto:module:prompt' theme 'pure'

# Pure prompt: lime green git branch
zstyle ':prompt:pure:git:branch' color '#32CD32'

# Editor key bindings (emacs style)
zstyle ':prezto:module:editor' key-bindings 'emacs'
